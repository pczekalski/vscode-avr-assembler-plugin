{
  "name": "avr-assembler",
  "displayName": "AVR Assembler Toolbox",
  "description": "AVR plugin for Assembler code compilation, linking and uploads",
  "version": "0.1.0",
  "publisher": "Piotr Czekalski",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:avr-asm-builder.buildCurrentFile",
    "onCommand:avr-asm-builder.uploadCurrentHex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "avr-asm-builder.buildCurrentFile",
        "title": "AVR: Build Current .s File"
      },
      {
        "command": "avr-asm-builder.uploadCurrentHex",
        "title": "AVR: Upload Current HEX"
      },
      {
        "command": "avr-asm-builder.selectUploadPort",
        "title": "AVR: Select Upload Port"
      }
    ],
    "configuration": {
      "title": "AVR ASM Builder",
      "properties": {
        "avr-asm-builder.mcu": {
          "type": "string",
          "default": "atmega328p",
          "description": "MCU passed to avr-gcc via -mmcu="
        },
        "avr-asm-builder.avrGccPath": {
          "type": "string",
          "default": "avr-gcc",
          "description": "Path or command name for avr-gcc"
        },
        "avr-asm-builder.avrObjcopyPath": {
          "type": "string",
          "default": "avr-objcopy",
          "description": "Path or command name for avr-objcopy"
        },
        "avr-asm-builder.avrSizePath": {
          "type": "string",
          "default": "avr-size",
          "description": "Path or command name for avr-size"
        },
        "avr-asm-builder.outputDirectory": {
          "type": "string",
          "default": "build",
          "description": "Directory relative to workspace or source file where build artifacts are written"
        },
        "avr-asm-builder.useNoStartFiles": {
          "type": "boolean",
          "default": true,
          "description": "Link with -nostartfiles for pure assembly projects"
        },
        "avr-asm-builder.avrdudePath": {
          "type": "string",
          "default": "avrdude",
          "description": "Path or command name for avrdude"
        },
        "avr-asm-builder.avrdudeProgrammer": {
          "type": "string",
          "default": "arduino",
          "description": "Programmer passed to avrdude via -c"
        },
        "avr-asm-builder.avrdudeBaud": {
          "type": "number",
          "default": 115200,
          "description": "Baud rate passed to avrdude via -b"
        },
        "avr-asm-builder.avrdudePort": {
          "type": "string",
          "default": "/dev/ttyUSB0",
          "description": "Upload port passed to avrdude via -P. You can type it manually or use the 'AVR: Select Upload Port' command."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "avr-asm-builder.buildCurrentFile",
          "when": "resourceExtname == .s",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}